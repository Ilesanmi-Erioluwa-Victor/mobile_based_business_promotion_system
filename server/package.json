{
  "name": "bizpromo-server",
  "version": "1.0.0",
  "description": "Express and MongoDB backend for BizPromo.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "test": "cross-env NODE_ENV=test jest --runInBand"
  },
  "dependencies": {
    "axios": "^1.7.9",
